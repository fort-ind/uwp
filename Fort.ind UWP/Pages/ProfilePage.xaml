<Page
    x:Class="Fort.ind_UWP.ProfilePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Fort.ind_UWP"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="Transparent">

    <Page.Resources>
        <Storyboard x:Key="AvatarFadeIn">
            <DoubleAnimation Storyboard.TargetName="AvatarGrid"
                             Storyboard.TargetProperty="Opacity"
                             From="0" To="1"
                             Duration="0:0:0.4"
                             EasingFunction="{StaticResource FadeEase}"/>
        </Storyboard>
        <CubicEase x:Key="FadeEase" EasingMode="EaseOut"/>
        <AcrylicBrush x:Key="CardAcrylicBrush"
                      BackgroundSource="Backdrop"
                      TintColor="{ThemeResource SystemChromeMediumHighColor}"
                      TintOpacity="0.6"
                      FallbackColor="{ThemeResource SystemChromeMediumHighColor}"/>
    </Page.Resources>

    <ScrollViewer>
        <StackPanel Padding="24" MaxWidth="600">
            
            <!-- Not Logged In State -->
            <StackPanel x:Name="NotLoggedInPanel" Visibility="Collapsed">
                <Grid Background="{StaticResource CardAcrylicBrush}"
                      CornerRadius="8"
                      Padding="24">
                    <StackPanel HorizontalAlignment="Center" Spacing="16">
                        <TextBlock Text="??" 
                                   FontSize="48" 
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="Not signed in"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="Sign in to access your profile and sync your data"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"
                                   Opacity="0.7"/>
                        <Button x:Name="SignInButton"
                                Content="Sign In"
                                HorizontalAlignment="Center"
                                Click="SignInButton_Click"
                                Style="{StaticResource AccentButtonStyle}"/>
                    </StackPanel>
                </Grid>
            </StackPanel>

            <!-- Logged In State -->
            <StackPanel x:Name="LoggedInPanel" Spacing="16">
                
                <!-- Profile Header -->
                <Grid Background="{StaticResource CardAcrylicBrush}"
                      CornerRadius="8"
                      Padding="24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Profile Picture -->
                    <Grid x:Name="AvatarGrid"
                          Width="80" Height="80" 
                          CornerRadius="40"
                          Background="{ThemeResource SystemControlBackgroundBaseLowBrush}"
                          Opacity="0">
                                                <Image x:Name="ProfileImage"
                                                             Stretch="UniformToFill"
                                                             Visibility="Collapsed"/>
                        <TextBlock x:Name="ProfileInitials"
                                   Text="?"
                                   FontSize="32"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Grid>

                    <!-- Profile Info -->
                    <StackPanel Grid.Column="1" Margin="16,0,0,0" VerticalAlignment="Center">
                        <TextBlock x:Name="DisplayNameText"
                                   Text="Display Name"
                                   FontSize="24"
                                   FontWeight="Bold"/>
                        <TextBlock x:Name="UsernameText"
                                   Text="@username"
                                   FontSize="14"
                                   Opacity="0.7"/>
                        <TextBlock x:Name="MemberSinceText"
                                   Text="Member since..."
                                   FontSize="12"
                                   Opacity="0.5"
                                   Margin="0,4,0,0"/>
                        <TextBlock x:Name="LastLoginText"
                                   Text=""
                                   FontSize="12"
                                   Opacity="0.5"
                                   Margin="0,2,0,0"
                                   Visibility="Collapsed"/>
                    </StackPanel>
                </Grid>

                <!-- View Mode -->
                <StackPanel x:Name="ViewModePanel" Spacing="16">
                    
                    <!-- Bio Section -->
                    <Grid Background="{StaticResource CardAcrylicBrush}"
                          CornerRadius="8"
                          Padding="20">
                        <StackPanel>
                            <TextBlock Text="About"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,8"/>
                            <TextBlock x:Name="BioText"
                                       Text="No bio yet"
                                       TextWrapping="Wrap"
                                       Opacity="0.8"/>
                        </StackPanel>
                    </Grid>

                    <!-- Contact Info -->
                    <Grid Background="{StaticResource CardAcrylicBrush}"
                          CornerRadius="8"
                          Padding="20">
                        <StackPanel Spacing="12">
                            <TextBlock Text="Contact"
                                       FontSize="16"
                                       FontWeight="SemiBold"/>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="??" FontSize="16"/>
                                <TextBlock x:Name="EmailText" 
                                           Text="No email set"
                                           Opacity="0.8"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>

                    <!-- Actions -->
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <Button x:Name="EditProfileButton"
                                Content="?? Edit Profile"
                                Click="EditProfileButton_Click"
                                AccessKey="E"
                                AutomationProperties.Name="Edit profile button"
                                AutomationProperties.HelpText="Edit your profile information (Alt+E)"/>
                        <Button x:Name="LogoutButton"
                                Content="?? Sign Out"
                                Click="LogoutButton_Click"
                                AccessKey="O"
                                AutomationProperties.Name="Sign out button"
                                AutomationProperties.HelpText="Sign out of your account (Alt+O)"/>
                    </StackPanel>
                </StackPanel>

                <!-- Edit Mode -->
                <StackPanel x:Name="EditModePanel" Spacing="16" Visibility="Collapsed">
                    
                    <Grid Background="{StaticResource CardAcrylicBrush}"
                          CornerRadius="8"
                          Padding="20">
                        <StackPanel Spacing="16">
                            <TextBlock Text="Edit Profile"
                                       FontSize="18"
                                       FontWeight="SemiBold"/>

                            <StackPanel Spacing="4">
                                <TextBlock Text="Display Name" FontSize="12" Opacity="0.7"/>
                                <TextBox x:Name="EditDisplayNameBox"
                                         AutomationProperties.Name="Display name"
                                         AutomationProperties.HelpText="Enter your display name"/>
                            </StackPanel>

                            <StackPanel Spacing="4">
                                <TextBlock Text="Email" FontSize="12" Opacity="0.7"/>
                                <TextBox x:Name="EditEmailBox"
                                         InputScope="EmailSmtpAddress"
                                         AutomationProperties.Name="Email address"
                                         AutomationProperties.HelpText="Enter your email address"/>
                            </StackPanel>

                            <StackPanel Spacing="4">
                                <TextBlock Text="Bio" FontSize="12" Opacity="0.7"/>
                                <TextBox x:Name="EditBioBox"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         MinHeight="100"
                                         AutomationProperties.Name="Bio"
                                         AutomationProperties.HelpText="Enter your bio or description"/>
                            </StackPanel>

                            <StackPanel Spacing="8">
                                <TextBlock Text="Profile Picture" FontSize="12" Opacity="0.7"/>
                                <StackPanel Orientation="Horizontal" Spacing="12">
                                    <Button x:Name="ChoosePhotoButton"
                                            Content="Choose Photo"
                                            Click="ChoosePhotoButton_Click"/>
                                    <Button x:Name="RemovePhotoButton"
                                            Content="Remove"
                                            Click="RemovePhotoButton_Click"/>
                                </StackPanel>
                                <TextBlock x:Name="PhotoStatusText"
                                           FontSize="12"
                                           Opacity="0.75"
                                           Visibility="Collapsed"/>
                            </StackPanel>

                            <TextBlock x:Name="EditErrorText"
                                       Foreground="{ThemeResource SystemControlErrorTextForegroundBrush}"
                                       FontSize="12"
                                       Visibility="Collapsed"/>
                            
                            <TextBlock x:Name="EditSuccessText"
                                       Foreground="#4CAF50"
                                       FontSize="12"
                                       Visibility="Collapsed"/>

                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <Button x:Name="SaveProfileButton"
                                        Content="Save Changes"
                                        Click="SaveProfileButton_Click"
                                        Style="{StaticResource AccentButtonStyle}"
                                        AutomationProperties.Name="Save changes button"
                                        AutomationProperties.HelpText="Save all profile changes"/>
                                <Button x:Name="CancelEditButton"
                                        Content="Cancel"
                                        Click="CancelEditButton_Click"
                                        AutomationProperties.Name="Cancel button"
                                        AutomationProperties.HelpText="Cancel editing and return to view mode"/>
                                <ProgressRing x:Name="SaveProfileProgress"
                                              Width="24"
                                              Height="24"
                                              IsActive="False"
                                              Visibility="Collapsed"
                                              VerticalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>

                    <!-- Change Password Section -->
                    <Grid Background="{StaticResource CardAcrylicBrush}"
                          CornerRadius="8"
                          Padding="20">
                        <StackPanel Spacing="16">
                            <TextBlock Text="Change Password"
                                       FontSize="18"
                                       FontWeight="SemiBold"/>

                            <StackPanel Spacing="4">
                                <TextBlock Text="Current Password" FontSize="12" Opacity="0.7"/>
                                <PasswordBox x:Name="CurrentPasswordBox"
                                             AutomationProperties.Name="Current password"
                                             AutomationProperties.HelpText="Enter your current password"/>
                            </StackPanel>

                            <StackPanel Spacing="4">
                                <TextBlock Text="New Password" FontSize="12" Opacity="0.7"/>
                                <PasswordBox x:Name="NewPasswordBox"
                                             PasswordChanged="NewPasswordBox_PasswordChanged"
                                             AutomationProperties.Name="New password"
                                             AutomationProperties.HelpText="Enter your new password"/>
                                <TextBlock x:Name="NewPasswordStrengthText"
                                           FontSize="11"
                                           Margin="0,-2,0,0"
                                           Visibility="Collapsed"
                                           AutomationProperties.LiveSetting="Polite"/>
                            </StackPanel>

                            <StackPanel Spacing="4">
                                <TextBlock Text="Confirm New Password" FontSize="12" Opacity="0.7"/>
                                <PasswordBox x:Name="ConfirmNewPasswordBox"
                                             AutomationProperties.Name="Confirm new password"
                                             AutomationProperties.HelpText="Re-enter your new password to confirm"/>
                            </StackPanel>

                            <TextBlock x:Name="PasswordErrorText"
                                       Foreground="{ThemeResource SystemControlErrorTextForegroundBrush}"
                                       FontSize="12"
                                       Visibility="Collapsed"/>
                            
                            <TextBlock x:Name="PasswordSuccessText"
                                       Foreground="#4CAF50"
                                       FontSize="12"
                                       Visibility="Collapsed"/>

                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <Button x:Name="ChangePasswordButton"
                                        Content="Update Password"
                                        Click="ChangePasswordButton_Click"
                                        AutomationProperties.Name="Update password button"
                                        AutomationProperties.HelpText="Change your account password"/>
                                <ProgressRing x:Name="ChangePasswordProgress"
                                              Width="24"
                                              Height="24"
                                              IsActive="False"
                                              Visibility="Collapsed"
                                              VerticalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>

                    <!-- Danger Zone -->
                    <Grid Background="{ThemeResource SystemControlErrorTextForegroundBrush}"
                          Opacity="0.15"
                          CornerRadius="8"/>
                    <Grid CornerRadius="8"
                          Padding="20">
                        <StackPanel Spacing="12">
                            <TextBlock Text="?? Danger Zone"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="{ThemeResource SystemControlErrorTextForegroundBrush}"/>
                            <TextBlock Text="Deleting your account is permanent and cannot be undone."
                                       TextWrapping="Wrap"
                                       Opacity="0.7"/>
                            <Button x:Name="DeleteAccountButton"
                                    Content="Delete Account"
                                    Background="{ThemeResource SystemControlErrorTextForegroundBrush}"
                                    Click="DeleteAccountButton_Click"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>
