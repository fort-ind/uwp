<Page
    x:Class="Fort.ind_UWP.LoginPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Fort.ind_UWP"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    mc:Ignorable="d"
    Background="Transparent"
    Loaded="LoginPage_Loaded">

    <Page.Resources>
        <!-- Acrylic background -->
        <AcrylicBrush x:Key="LoginAcrylicBrush"
                      BackgroundSource="HostBackdrop"
                      TintColor="{ThemeResource SystemChromeMediumLowColor}"
                      TintOpacity="0.7"
                      FallbackColor="{ThemeResource SystemChromeMediumLowColor}"/>

        <!-- Card background -->
        <AcrylicBrush x:Key="CardAcrylicBrush"
                      BackgroundSource="Backdrop"
                      TintColor="{ThemeResource SystemChromeMediumHighColor}"
                      TintOpacity="0.7"
                      FallbackColor="{ThemeResource SystemChromeMediumHighColor}"/>
    </Page.Resources>

    <Grid Background="{StaticResource LoginAcrylicBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="32"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Title Bar -->
        <Grid x:Name="AppTitleBar"
              Grid.Row="0"
              Background="Transparent"
              HorizontalAlignment="Stretch">
            <TextBlock Text=""
                       VerticalAlignment="Center"
                       Margin="12,0,0,0"
                       Style="{StaticResource CaptionTextBlockStyle}"
                       Opacity="0.8"/>
        </Grid>

        <!-- Main Content -->
        <Grid Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center">
            <Grid Background="{StaticResource CardAcrylicBrush}"
                  CornerRadius="4"
                  Padding="40"
                  MinWidth="380"
                  MaxWidth="420">

                <StackPanel Spacing="16">
                    <!-- Logo/Title -->
                    <StackPanel HorizontalAlignment="Center" Margin="0,0,0,16">
                        <FontIcon Glyph="&#xE72E;"
                                  FontSize="48"
                                  HorizontalAlignment="Center"/>
                        <TextBlock Text="fort.desktop"
                                   Style="{StaticResource TitleTextBlockStyle}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="Sign in with your fort.social account"
                                   Style="{StaticResource BodyTextBlockStyle}"
                                   Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                                   HorizontalAlignment="Center"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"/>
                    </StackPanel>

                    <TextBlock Text="You'll be taken to fort.social to login to your account you will be taken back here after signing in!"
                               FontSize="12"
                               Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                               TextWrapping="Wrap"
                               TextAlignment="Center"/>

                    <TextBlock x:Name="ErrorText"
                               Foreground="{ThemeResource SystemControlErrorTextForegroundBrush}"
                               FontSize="12"
                               TextWrapping="Wrap"
                               TextAlignment="Center"
                               Visibility="Collapsed"
                               AutomationProperties.LiveSetting="Assertive"/>

                    <Button x:Name="SignInButton"
                            HorizontalAlignment="Stretch"
                            Click="SignInButton_Click"
                            Style="{StaticResource AccentButtonStyle}"
                            AutomationProperties.Name="Sign in with fort.social"
                            AutomationProperties.HelpText="Opens fort.social in your browser to approve sign-in">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="8">
                            <FontIcon Glyph="&#xE774;" FontSize="14"/>
                            <TextBlock Text="Sign in with fort.social"/>
                        </StackPanel>
                    </Button>

                    <!-- Skip for now option -->
                    <HyperlinkButton x:Name="SkipButton"
                                     Content="skip connecting your account"
                                     HorizontalAlignment="Center"
                                     Click="SkipButton_Click"
                                     AutomationProperties.Name="Skip sign in"
                                     AutomationProperties.HelpText="Continue using the app without signing in"/>

                    <muxc:TeachingTip x:Name="SkipHintTip"
                                      Target="{x:Bind SkipButton}"
                                      Title="dont have an account?"
                                      Subtitle="dont have a account? or if you dont wanna login thats perfectly fine! but in the future you might want to connect your account."
                                      PreferredPlacement="Bottom"
                                      CloseButtonContent="alrighty :)"/>
                </StackPanel>
            </Grid>
        </Grid>

        <!-- Loading overlay -->
        <Grid x:Name="LoadingOverlay"
              Grid.RowSpan="2"
              Background="{ThemeResource SystemControlPageBackgroundMediumAltMediumBrush}"
              Visibility="Collapsed">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8">
                <ProgressRing IsActive="True" Width="40" Height="40" HorizontalAlignment="Center"
                              AutomationProperties.Name="Waiting for sign-in"/>
                <TextBlock Text="Waiting for fort.social in your browser..." Margin="0,12,0,0"
                           Foreground="{ThemeResource SystemControlForegroundBaseMediumHighBrush}"
                           TextAlignment="Center"
                           AutomationProperties.LiveSetting="Polite"/>
                <HyperlinkButton x:Name="CancelSignInButton"
                                 Content="Cancel"
                                 HorizontalAlignment="Center"
                                 Click="CancelSignInButton_Click"
                                 AutomationProperties.Name="Cancel sign-in"/>
            </StackPanel>
        </Grid>
    </Grid>
</Page>
