<Page
    x:Class="Fort.ind_UWP.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Fort.ind_UWP"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="Transparent">

    <Page.Resources>
        <!-- App Background - Windows 10 Settings style acrylic -->
        <AcrylicBrush x:Key="AppAcrylicBrush"
                      BackgroundSource="HostBackdrop"
                      TintColor="{ThemeResource SystemChromeMediumLowColor}"
                      TintOpacity="0.8"
                      FallbackColor="{ThemeResource SystemChromeMediumLowColor}"/>

        <!-- NavigationView Pane Acrylic - matches Windows 10 Settings sidebar -->
        <AcrylicBrush x:Key="NavigationViewExpandedPaneBackground"
                      BackgroundSource="HostBackdrop"
                      TintColor="{ThemeResource SystemChromeMediumColor}"
                      TintOpacity="0.9"
                      FallbackColor="{ThemeResource SystemChromeMediumColor}"/>

        <!-- Card Background - more prominent acrylic effect -->
        <AcrylicBrush x:Key="CardAcrylicBrush"
                      BackgroundSource="HostBackdrop"
                      TintColor="{ThemeResource SystemChromeMediumHighColor}"
                      TintOpacity="0.7"
                      FallbackColor="{ThemeResource SystemChromeMediumHighColor}"/>
    </Page.Resources>

    <Grid x:Name="RootGrid" Background="{StaticResource AppAcrylicBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="32"/>
            <RowDefinition Height="137*"/>
            <RowDefinition Height="347*"/>
        </Grid.RowDefinitions>

        <!-- Custom Title Bar Area -->
        <Grid x:Name="AppTitleBar" 
              Grid.Row="0" 
              Background="Transparent">
            <TextBlock Text="Fort.ind"
                       VerticalAlignment="Center"
                       Margin="12,0,0,0"
                       Style="{StaticResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource SystemControlForegroundBaseMediumHighBrush}"/>
            
            <!-- Loading Indicator for Sitemap -->
            <ProgressRing x:Name="LoadingIndicator"
                          IsActive="False"
                          Visibility="Collapsed"
                          Width="16"
                          Height="16"
                          HorizontalAlignment="Right"
                          VerticalAlignment="Center"
                          Margin="0,0,12,0"
                          Foreground="{ThemeResource SystemAccentColor}"/>
        </Grid>

        <!-- Main Content -->
        <NavigationView x:Name="NavView"
                         Grid.Row="1"
                         PaneDisplayMode="Auto"
                         CompactPaneLength="48"
                         OpenPaneLength="320"
                         IsBackButtonVisible="Collapsed"
                         IsSettingsVisible="True"
                         IsPaneToggleButtonVisible="True"
                         ItemInvoked="NavView_ItemInvoked"
                         Loaded="NavView_Loaded"
                         DisplayModeChanged="NavView_DisplayModeChanged"
                         Background="Transparent" Grid.RowSpan="2">

            <NavigationView.Resources>
                <!-- Every pane glyph must centre on 24px (half of the 48px compact pane).
                     The toggle button is sized by its own resource, not CompactPaneLength,
                     so it has to be widened to 48 as well or the hamburger sits 4px left. -->
                <x:Double x:Key="NavigationViewCompactPaneLength">48</x:Double>
                <x:Double x:Key="PaneToggleButtonWidth">48</x:Double>
                <Thickness x:Key="NavigationViewItemIconBoxMargin">16,12,16,12</Thickness>
            </NavigationView.Resources>

            <!-- Page titles live here rather than in the content, so the floating pane
                 toggle button cannot overlap them in Minimal mode. The header host
                 already carries a 12px left margin (48px in Minimal, to clear the
                 toggle button), so 12 more lands the text on the content's 24px
                 padding, and leaves a 12px gap after the toggle button in Minimal. -->
            <NavigationView.HeaderTemplate>
                <DataTemplate>
                    <!-- Top, not Center: the header box starts 5px below the toggle
                         button's, so centring here drops the title below the button. -->
                    <TextBlock Text="{Binding}"
                               Style="{StaticResource TitleTextBlockStyle}"
                               VerticalAlignment="Top"
                               TextTrimming="CharacterEllipsis"
                               Margin="12,0,12,0"/>
                </DataTemplate>
            </NavigationView.HeaderTemplate>

            <NavigationView.AutoSuggestBox>
                <AutoSuggestBox x:Name="NavSearchBox"
                                PlaceholderText="Search for games, pages, and more..."
                                QueryIcon="Find"
                                MaxSuggestionListHeight="400"
                                AutomationProperties.Name="Search for games, pages and more"
                                TextChanged="NavSearchBox_TextChanged"
                                QuerySubmitted="NavSearchBox_QuerySubmitted"
                                SuggestionChosen="NavSearchBox_SuggestionChosen">
                    <AutoSuggestBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Spacing="10" Padding="0,4">
                                <FontIcon Glyph="{Binding Icon}"
                                          FontSize="16"
                                          VerticalAlignment="Center"
                                          Opacity="0.8"/>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Title}"/>
                                    <TextBlock Text="{Binding Category}"
                                               Style="{ThemeResource CaptionTextBlockStyle}"
                                               Foreground="{ThemeResource SystemControlForegroundBaseMediumLowBrush}"/>
                                </StackPanel>
                            </StackPanel>
                        </DataTemplate>
                    </AutoSuggestBox.ItemTemplate>
                </AutoSuggestBox>
            </NavigationView.AutoSuggestBox>

            <NavigationView.MenuItems>
                <NavigationViewItem Content="Home" Tag="LatestNews"
                                     ToolTipService.ToolTip="Home (Alt+H)"
                                     AccessKey="H"
                                     AutomationProperties.Name="Home"
                                     AutomationProperties.HelpText="Navigate to home page">
                    <NavigationViewItem.Icon>
                        <SymbolIcon Symbol="Home"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Games" Tag="Games"
                                     ToolTipService.ToolTip="Games (Alt+G)"
                                     AccessKey="G"
                                     AutomationProperties.Name="Games"
                                     AutomationProperties.HelpText="Browse games">
                    <NavigationViewItem.Icon>
                        <SymbolIcon Symbol="Play"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Beta Programs" Tag="Betas"
                                     ToolTipService.ToolTip="Beta Programs (Alt+B)"
                                     AccessKey="B"
                                     AutomationProperties.Name="Beta Programs"
                                     AutomationProperties.HelpText="Join beta programs">
                    <NavigationViewItem.Icon>
                        <SymbolIcon Symbol="PreviewLink"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem x:Name="ProfileNavItem" Content="Your Profile" Tag="Profile"
                                     ToolTipService.ToolTip="Your Profile (Alt+P)"
                                     AccessKey="P"
                                     AutomationProperties.Name="Your Profile"
                                     AutomationProperties.HelpText="View and edit your profile">
                    <NavigationViewItem.Icon>
                        <SymbolIcon Symbol="Contact"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Social" Tag="Social"
                                     ToolTipService.ToolTip="Social (Alt+S)"
                                     AccessKey="S"
                                     AutomationProperties.Name="Social"
                                     AutomationProperties.HelpText="Connect with the community">
                    <NavigationViewItem.Icon>
                        <SymbolIcon Symbol="People"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>

            <!-- Content Area -->
            <Grid Background="Transparent">
                <!-- Frame for page navigation -->
                <Frame x:Name="ContentFrame" Visibility="Collapsed"/>

                <ScrollViewer x:Name="ContentScrollViewer">
                    <!-- Padding is set from NavView_DisplayModeChanged: 12px in Minimal, 24px otherwise. -->
                    <StackPanel x:Name="ContentPanel">
                        <!-- Latest News Content (default view) -->
                        <StackPanel x:Name="LatestNewsPanel" Visibility="Visible">
                            <TextBlock Text="Check back here for the latest updates and announcements."
                                       Style="{StaticResource BodyTextBlockStyle}"
                                       Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                                       Margin="0,0,0,24"/>

                            <!-- News Cards Grid -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- News Card 1 -->
                                <Grid Grid.Column="0"
                                      Background="{StaticResource CardAcrylicBrush}"
                                      CornerRadius="4"
                                      Padding="20"
                                      MinHeight="180">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Spacing="6"
                                                    Opacity="0.6" Margin="0,0,0,8">
                                            <FontIcon Glyph="&#xE789;" FontSize="12" VerticalAlignment="Center"/>
                                            <TextBlock Text="Welcome!"
                                                       Style="{StaticResource CaptionTextBlockStyle}"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <TextBlock Text="welcome to version 2.0 of fort.uwp!"
                                                   Style="{StaticResource SubtitleTextBlockStyle}"
                                                   TextWrapping="Wrap"
                                                   Margin="0,0,0,12"/>
                                        <TextBlock Text="this update fixes many bugs add new features and we also added syncing accounts with fort.social"
                                                   Style="{StaticResource BodyTextBlockStyle}"
                                                   TextWrapping="Wrap"
                                                   Foreground="{ThemeResource SystemControlForegroundBaseMediumHighBrush}"
                                                   Margin="0,0,0,12"/>
                                        <TextBlock Text="Just now"
                                                   Style="{StaticResource CaptionTextBlockStyle}"
                                                   Foreground="{ThemeResource SystemControlForegroundBaseMediumLowBrush}"/>
                                    </StackPanel>
                                </Grid>

                                <!-- News Card 2 -->
                                <Grid Grid.Column="2"
                                      Background="{StaticResource CardAcrylicBrush}"
                                      CornerRadius="4"
                                      Padding="20"
                                      MinHeight="180">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Spacing="6"
                                                    Opacity="0.6" Margin="0,0,0,8">
                                            <FontIcon Glyph="&#xE7FC;" FontSize="12" VerticalAlignment="Center"/>
                                            <TextBlock Text="soon! :3"
                                                       Style="{StaticResource CaptionTextBlockStyle}"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <TextBlock Text="soon soon soon-"
                                                   Style="{StaticResource SubtitleTextBlockStyle}"
                                                   TextWrapping="Wrap"
                                                   Margin="0,0,0,12"/>
                                        <TextBlock Text="soon you will be able to manage your fort.ind account, view posts from social and play your games from fort1nd.com on windows! if you want to use the full experience for now go to fort1nd.com"
                                                   Style="{StaticResource BodyTextBlockStyle}"
                                                   TextWrapping="Wrap"
                                                   Foreground="{ThemeResource SystemControlForegroundBaseMediumHighBrush}"
                                                   Margin="0,0,0,12"/>
                                        <TextBlock Text="in the future (maybe subject to change)"
                                                   Style="{StaticResource CaptionTextBlockStyle}"
                                                   Foreground="{ThemeResource SystemControlForegroundBaseMediumLowBrush}"/>
                                    </StackPanel>
                                </Grid>
                            </Grid>
                        </StackPanel>

                        <!-- Games Content -->
                        <StackPanel x:Name="GamesPanel" Visibility="Collapsed">
                            <TextBlock Text="Visit https://www.fort1nd.com to explore our games"
                                       Style="{StaticResource BodyTextBlockStyle}"
                                       TextWrapping="Wrap"/>
                        </StackPanel>

                        <!-- Betas Content -->
                        <StackPanel x:Name="BetasPanel" Visibility="Collapsed">
                            <TextBlock Text="Access beta versions and early features (coming soon)"
                                       Style="{StaticResource BodyTextBlockStyle}"
                                       TextWrapping="Wrap"/>
                        </StackPanel>

                        <!-- Profile Content is now handled by ProfilePage via Frame -->

                        <!-- Social Content -->
                        <StackPanel x:Name="SocialPanel" Visibility="Collapsed">
                            <TextBlock Text="Social features coming soon"
                                       Style="{StaticResource BodyTextBlockStyle}"
                                       TextWrapping="Wrap"/>
                        </StackPanel>

                        <!-- Settings Content -->
                        <StackPanel x:Name="SettingsPanel" Visibility="Collapsed">
                            <TextBlock Text="make fort.desktop work for you :3 change it to how you like"
                                       Style="{StaticResource BodyTextBlockStyle}"
                                       Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                                       Margin="0,0,0,24"/>

                            <StackPanel MaxWidth="700" HorizontalAlignment="Stretch" Spacing="0">
                                <StackPanel.ChildrenTransitions>
                                    <TransitionCollection>
                                        <EntranceThemeTransition FromVerticalOffset="40"/>
                                        <RepositionThemeTransition/>
                                    </TransitionCollection>
                                </StackPanel.ChildrenTransitions>

                                <!-- ═══ Appearance ═══ -->
                                <Border BorderThickness="0,0,0,1"
                                        BorderBrush="{ThemeResource SystemControlForegroundBaseLowBrush}">
                                    <StackPanel>
                                        <Button Style="{StaticResource ButtonRevealStyle}"
                                                HorizontalAlignment="Stretch"
                                                HorizontalContentAlignment="Stretch"
                                                MinWidth="0"
                                                CornerRadius="0"
                                                Padding="16,12"
                                                Click="AppearanceHeader_Tapped"
                                                AutomationProperties.Name="Appearance"
                                                AutomationProperties.HelpText="Change app theme and background color">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <Grid Width="36" Height="36" CornerRadius="2"
                                                      Background="{ThemeResource SystemControlBackgroundBaseLowBrush}">
                                                    <FontIcon Glyph="&#xE771;" FontSize="16"
                                                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Grid>
                                                <StackPanel Grid.Column="1" Margin="16,0,0,0" VerticalAlignment="Center">
                                                    <TextBlock Text="Appearance" Style="{StaticResource BaseTextBlockStyle}"/>
                                                    <TextBlock Text="Change app theme and background color"
                                                               Style="{StaticResource CaptionTextBlockStyle}"
                                                               Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                                                </StackPanel>
                                                <FontIcon x:Name="AppearanceChevron" Grid.Column="2" Glyph="&#xE76C;"
                                                          FontSize="12" VerticalAlignment="Center"
                                                          Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                                                          RenderTransformOrigin="0.5,0.5">
                                                    <FontIcon.RenderTransform>
                                                        <RotateTransform x:Name="AppearanceChevronRotation" Angle="0"/>
                                                    </FontIcon.RenderTransform>
                                                </FontIcon>
                                            </Grid>
                                        </Button>
                                        <StackPanel x:Name="AppearanceContent" Visibility="Collapsed"
                                                    Padding="20,0,20,16">
                                            <StackPanel.ChildrenTransitions>
                                                <TransitionCollection>
                                                    <EntranceThemeTransition FromVerticalOffset="20"/>
                                                </TransitionCollection>
                                            </StackPanel.ChildrenTransitions>
                                            <Rectangle Height="1" Margin="0,0,0,14"
                                                       Fill="{ThemeResource SystemControlForegroundBaseHighBrush}"
                                                       Opacity="0.08"/>
                                            <StackPanel Spacing="16">
                                                <StackPanel Spacing="8">
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <FontIcon Glyph="&#xE793;" FontSize="14" Opacity="0.7"/>
                                                        <TextBlock Text="App Theme" Style="{StaticResource BodyTextBlockStyle}" FontWeight="SemiBold"/>
                                                    </StackPanel>
                                                    <StackPanel Orientation="Horizontal" Spacing="16">
                                                        <RadioButton x:Name="ThemeSystemRadio" Content="System Default"
                                                                     GroupName="AppTheme" Tag="Default"
                                                                     Checked="ThemeRadio_Checked"/>
                                                        <RadioButton x:Name="ThemeLightRadio" Content="Light"
                                                                     GroupName="AppTheme" Tag="Light"
                                                                     Checked="ThemeRadio_Checked"/>
                                                        <RadioButton x:Name="ThemeDarkRadio" Content="Dark"
                                                                     GroupName="AppTheme" Tag="Dark"
                                                                     Checked="ThemeRadio_Checked"/>
                                                    </StackPanel>
                                                </StackPanel>
                                                <StackPanel Spacing="8">
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <FontIcon Glyph="&#xE771;" FontSize="14" Opacity="0.7"/>
                                                        <TextBlock Text="Background Tint" Style="{StaticResource BodyTextBlockStyle}" FontWeight="SemiBold"/>
                                                    </StackPanel>
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <Button x:Name="TintDefaultButton" Tag="Default"
                                                                Click="TintColorButton_Click"
                                                                Width="32" Height="32" Padding="0" MinWidth="32"
                                                                BorderThickness="2" BorderBrush="Transparent"
                                                                ToolTipService.ToolTip="Default"
                                                                AutomationProperties.Name="Default background tint">
                                                            <FontIcon Glyph="&#xE8D8;" FontSize="14"/>
                                                        </Button>
                                                        <Button x:Name="TintBlueButton" Tag="#1E3A5F"
                                                                Click="TintColorButton_Click"
                                                                Width="32" Height="32" Padding="0" MinWidth="32"
                                                                Background="#1D6FA5" BorderThickness="2"
                                                                BorderBrush="Transparent"
                                                                ToolTipService.ToolTip="Navy Blue"
                                                                AutomationProperties.Name="Navy Blue background tint"/>
                                                        <Button x:Name="TintPurpleButton" Tag="#2D1B69"
                                                                Click="TintColorButton_Click"
                                                                Width="32" Height="32" Padding="0" MinWidth="32"
                                                                Background="#6041B0" BorderThickness="2"
                                                                BorderBrush="Transparent"
                                                                ToolTipService.ToolTip="Deep Purple"
                                                                AutomationProperties.Name="Deep Purple background tint"/>
                                                        <Button x:Name="TintGreenButton" Tag="#0F3D2E"
                                                                Click="TintColorButton_Click"
                                                                Width="32" Height="32" Padding="0" MinWidth="32"
                                                                Background="#1B7A4E" BorderThickness="2"
                                                                BorderBrush="Transparent"
                                                                ToolTipService.ToolTip="Forest Green"
                                                                AutomationProperties.Name="Forest Green background tint"/>
                                                        <Button x:Name="TintRedButton" Tag="#3D1515"
                                                                Click="TintColorButton_Click"
                                                                Width="32" Height="32" Padding="0" MinWidth="32"
                                                                Background="#B03232" BorderThickness="2"
                                                                BorderBrush="Transparent"
                                                                ToolTipService.ToolTip="Deep Red"
                                                                AutomationProperties.Name="Deep Red background tint"/>
                                                        <Button x:Name="TintSlateButton" Tag="#1A1A2E"
                                                                Click="TintColorButton_Click"
                                                                Width="32" Height="32" Padding="0" MinWidth="32"
                                                                Background="#404080" BorderThickness="2"
                                                                BorderBrush="Transparent"
                                                                ToolTipService.ToolTip="Dark Slate"
                                                                AutomationProperties.Name="Dark Slate background tint"/>
                                                    </StackPanel>
                                                </StackPanel>
                                            </StackPanel>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <!-- ═══ Data Storage ═══ -->
                                <Border BorderThickness="0,0,0,1"
                                        BorderBrush="{ThemeResource SystemControlForegroundBaseLowBrush}">
                                    <StackPanel>
                                        <Button Style="{StaticResource ButtonRevealStyle}"
                                                HorizontalAlignment="Stretch"
                                                HorizontalContentAlignment="Stretch"
                                                MinWidth="0"
                                                CornerRadius="0"
                                                Padding="16,12"
                                                Click="StorageHeader_Tapped"
                                                AutomationProperties.Name="Data Storage"
                                                AutomationProperties.HelpText="Manage local storage and view account data">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <Grid Width="36" Height="36" CornerRadius="2"
                                                      Background="{ThemeResource SystemControlBackgroundBaseLowBrush}">
                                                    <FontIcon Glyph="&#xEDA2;" FontSize="16"
                                                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Grid>
                                                <StackPanel Grid.Column="1" Margin="16,0,0,0" VerticalAlignment="Center">
                                                    <TextBlock Text="Data Storage" Style="{StaticResource BaseTextBlockStyle}"/>
                                                    <TextBlock Text="Manage local storage and view account data"
                                                               Style="{StaticResource CaptionTextBlockStyle}"
                                                               Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                                                </StackPanel>
                                                <FontIcon x:Name="StorageChevron" Grid.Column="2" Glyph="&#xE76C;"
                                                          FontSize="12" VerticalAlignment="Center"
                                                          Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                                                          RenderTransformOrigin="0.5,0.5">
                                                    <FontIcon.RenderTransform>
                                                        <RotateTransform x:Name="StorageChevronRotation" Angle="0"/>
                                                    </FontIcon.RenderTransform>
                                                </FontIcon>
                                            </Grid>
                                        </Button>
                                        <StackPanel x:Name="StorageContent" Visibility="Collapsed"
                                                    Padding="20,0,20,16">
                                            <StackPanel.ChildrenTransitions>
                                                <TransitionCollection>
                                                    <EntranceThemeTransition FromVerticalOffset="20"/>
                                                </TransitionCollection>
                                            </StackPanel.ChildrenTransitions>
                                            <Rectangle Height="1" Margin="0,0,0,14"
                                                       Fill="{ThemeResource SystemControlForegroundBaseHighBrush}"
                                                       Opacity="0.08"/>
                                            <StackPanel Spacing="8">
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <FontIcon Glyph="&#xE8B7;" FontSize="14" Opacity="0.7"/>
                                                    <TextBlock Text="Local Cache"
                                                               Style="{StaticResource BodyTextBlockStyle}" FontWeight="SemiBold"/>
                                                </StackPanel>
                                                <TextBlock x:Name="CacheDescriptionText"
                                                           Text="Not signed in."
                                                           FontSize="12" TextWrapping="Wrap"
                                                           Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                                                           Margin="0,0,0,4"/>
                                                <TextBlock x:Name="StoragePathText"
                                                           FontSize="12" TextWrapping="Wrap"
                                                           Foreground="{ThemeResource SystemControlForegroundBaseMediumLowBrush}"/>
                                                <TextBlock x:Name="UserCountText"
                                                           FontSize="12"
                                                           Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                                                <StackPanel Orientation="Horizontal" Spacing="8"
                                                            HorizontalAlignment="Left"
                                                            Margin="0,4,0,0">
                                                    <Button x:Name="ClearLoginInfoButton"
                                                            Content="Clear login info"
                                                            Click="ClearLoginInfoButton_Click"
                                                            AutomationProperties.Name="Clear login info button"
                                                            AutomationProperties.HelpText="Signs you out and clears the cached fort.social login"/>
                                                    <Button x:Name="ResetAppButton"
                                                            Content="Reset app"
                                                            Click="ResetAppButton_Click"
                                                            Foreground="{ThemeResource SystemControlErrorTextForegroundBrush}"
                                                            AutomationProperties.Name="Reset app button"
                                                            AutomationProperties.HelpText="Signs you out and deletes all cached data and saved settings, resetting the app to a fresh install"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <!-- ═══ Live Tile ═══ -->
                                <Border BorderThickness="0,0,0,1"
                                        BorderBrush="{ThemeResource SystemControlForegroundBaseLowBrush}">
                                    <StackPanel>
                                        <Button Style="{StaticResource ButtonRevealStyle}"
                                                HorizontalAlignment="Stretch"
                                                HorizontalContentAlignment="Stretch"
                                                MinWidth="0"
                                                CornerRadius="0"
                                                Padding="16,12"
                                                Click="TileHeader_Tapped"
                                                AutomationProperties.Name="Live Tile"
                                                AutomationProperties.HelpText="Refresh or clear your Start menu tile">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <Grid Width="36" Height="36" CornerRadius="2"
                                                      Background="{ThemeResource SystemControlBackgroundBaseLowBrush}">
                                                    <FontIcon Glyph="&#xE77F;" FontSize="16"
                                                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Grid>
                                                <StackPanel Grid.Column="1" Margin="16,0,0,0" VerticalAlignment="Center">
                                                    <TextBlock Text="Live Tile" Style="{StaticResource BaseTextBlockStyle}"/>
                                                    <TextBlock Text="Refresh or clear your Start menu tile"
                                                               Style="{StaticResource CaptionTextBlockStyle}"
                                                               Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                                                </StackPanel>
                                                <FontIcon x:Name="TileChevron" Grid.Column="2" Glyph="&#xE76C;"
                                                          FontSize="12" VerticalAlignment="Center"
                                                          Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                                                          RenderTransformOrigin="0.5,0.5">
                                                    <FontIcon.RenderTransform>
                                                        <RotateTransform x:Name="TileChevronRotation" Angle="0"/>
                                                    </FontIcon.RenderTransform>
                                                </FontIcon>
                                            </Grid>
                                        </Button>
                                        <StackPanel x:Name="TileContent" Visibility="Collapsed"
                                                    Padding="20,0,20,16">
                                            <StackPanel.ChildrenTransitions>
                                                <TransitionCollection>
                                                    <EntranceThemeTransition FromVerticalOffset="20"/>
                                                </TransitionCollection>
                                            </StackPanel.ChildrenTransitions>
                                            <Rectangle Height="1" Margin="0,0,0,14"
                                                       Fill="{ThemeResource SystemControlForegroundBaseHighBrush}"
                                                       Opacity="0.08"/>
                                            <StackPanel Orientation="Horizontal" Spacing="12">
                                                <Button x:Name="RefreshTileButton"
                                                        Click="RefreshTileButton_Click"
                                                        Style="{StaticResource ButtonRevealStyle}">
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <FontIcon Glyph="&#xE72C;" FontSize="14"/>
                                                        <TextBlock Text="Refresh Live Tile"/>
                                                    </StackPanel>
                                                </Button>
                                                <Button x:Name="ClearTileButton"
                                                        Click="ClearTileButton_Click"
                                                        Style="{StaticResource ButtonRevealStyle}">
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <FontIcon Glyph="&#xE74D;" FontSize="14"/>
                                                        <TextBlock Text="Clear Live Tile"/>
                                                    </StackPanel>
                                                </Button>
                                            </StackPanel>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <!-- ═══ Welcome Dialog ═══ -->
                                <Border BorderThickness="0,0,0,1"
                                        BorderBrush="{ThemeResource SystemControlForegroundBaseLowBrush}">
                                    <StackPanel>
                                        <Button Style="{StaticResource ButtonRevealStyle}"
                                                HorizontalAlignment="Stretch"
                                                HorizontalContentAlignment="Stretch"
                                                MinWidth="0"
                                                CornerRadius="0"
                                                Padding="16,12"
                                                Click="WelcomeHeader_Tapped"
                                                AutomationProperties.Name="Welcome Dialog"
                                                AutomationProperties.HelpText="Reset the first-run welcome experience">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <Grid Width="36" Height="36" CornerRadius="2"
                                                      Background="{ThemeResource SystemControlBackgroundBaseLowBrush}">
                                                    <FontIcon Glyph="&#xEB51;" FontSize="16"
                                                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Grid>
                                                <StackPanel Grid.Column="1" Margin="16,0,0,0" VerticalAlignment="Center">
                                                    <TextBlock Text="Welcome Dialog" Style="{StaticResource BaseTextBlockStyle}"/>
                                                    <TextBlock Text="Reset the first-run welcome experience"
                                                               Style="{StaticResource CaptionTextBlockStyle}"
                                                               Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                                                </StackPanel>
                                                <FontIcon x:Name="WelcomeChevron" Grid.Column="2" Glyph="&#xE76C;"
                                                          FontSize="12" VerticalAlignment="Center"
                                                          Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                                                          RenderTransformOrigin="0.5,0.5">
                                                    <FontIcon.RenderTransform>
                                                        <RotateTransform x:Name="WelcomeChevronRotation" Angle="0"/>
                                                    </FontIcon.RenderTransform>
                                                </FontIcon>
                                            </Grid>
                                        </Button>
                                        <StackPanel x:Name="WelcomeContent" Visibility="Collapsed"
                                                    Padding="20,0,20,16">
                                            <StackPanel.ChildrenTransitions>
                                                <TransitionCollection>
                                                    <EntranceThemeTransition FromVerticalOffset="20"/>
                                                </TransitionCollection>
                                            </StackPanel.ChildrenTransitions>
                                            <Rectangle Height="1" Margin="0,0,0,12"
                                                       Fill="{ThemeResource SystemControlForegroundBaseHighBrush}"
                                                       Opacity="0.08"/>
                                            <StackPanel Spacing="10">
                                                <TextBlock Text="The welcome dialog appears the first time you open the app."
                                                           FontSize="12" TextWrapping="Wrap"
                                                           Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                                                <Button x:Name="ResetWelcomeButton"
                                                        Click="ResetWelcomeButton_Click"
                                                        Style="{StaticResource ButtonRevealStyle}">
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <FontIcon Glyph="&#xE72C;" FontSize="14"/>
                                                        <TextBlock Text="Show Welcome Dialog Again"/>
                                                    </StackPanel>
                                                </Button>
                                            </StackPanel>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <!-- ═══ About ═══ -->
                                <Border BorderThickness="0,0,0,1"
                                        BorderBrush="{ThemeResource SystemControlForegroundBaseLowBrush}">
                                    <StackPanel>
                                        <Button Style="{StaticResource ButtonRevealStyle}"
                                                HorizontalAlignment="Stretch"
                                                HorizontalContentAlignment="Stretch"
                                                MinWidth="0"
                                                CornerRadius="0"
                                                Padding="16,12"
                                                Click="AboutHeader_Tapped"
                                                AutomationProperties.Name="About"
                                                AutomationProperties.HelpText="Version info, credits, and more">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <Grid Width="36" Height="36" CornerRadius="2"
                                                      Background="{ThemeResource SystemControlBackgroundBaseLowBrush}">
                                                    <FontIcon Glyph="&#xE946;" FontSize="16"
                                                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Grid>
                                                <StackPanel Grid.Column="1" Margin="16,0,0,0" VerticalAlignment="Center">
                                                    <TextBlock Text="About" Style="{StaticResource BaseTextBlockStyle}"/>
                                                    <TextBlock Text="Version info, credits, and more"
                                                               Style="{StaticResource CaptionTextBlockStyle}"
                                                               Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                                                </StackPanel>
                                                <FontIcon x:Name="AboutChevron" Grid.Column="2" Glyph="&#xE76C;"
                                                          FontSize="12" VerticalAlignment="Center"
                                                          Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                                                          RenderTransformOrigin="0.5,0.5">
                                                    <FontIcon.RenderTransform>
                                                        <RotateTransform x:Name="AboutChevronRotation" Angle="0"/>
                                                    </FontIcon.RenderTransform>
                                                </FontIcon>
                                            </Grid>
                                        </Button>
                                        <StackPanel x:Name="AboutContent" Visibility="Collapsed"
                                                    Padding="20,0,20,16">
                                            <StackPanel.ChildrenTransitions>
                                                <TransitionCollection>
                                                    <EntranceThemeTransition FromVerticalOffset="20"/>
                                                </TransitionCollection>
                                            </StackPanel.ChildrenTransitions>
                                            <Rectangle Height="1" Margin="0,0,0,12"
                                                       Fill="{ThemeResource SystemControlForegroundBaseHighBrush}"
                                                       Opacity="0.08"/>
                                            <StackPanel Spacing="12">

                                                <!-- App identity -->
                                                <StackPanel Orientation="Horizontal" Spacing="14" VerticalAlignment="Center">
                                                    <Border Width="44" Height="44" CornerRadius="2"
                                                            Background="{ThemeResource SystemControlBackgroundBaseLowBrush}">
                                                        <FontIcon Glyph="&#xE774;" FontSize="22"
                                                                  HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"/>
                                                    </Border>
                                                    <StackPanel VerticalAlignment="Center" Spacing="4">
                                                        <TextBlock Text="Fort.ind" Style="{StaticResource SubtitleTextBlockStyle}"/>
                                                        <TextBlock x:Name="AboutVersionText"
                                                                   Text="Version"
                                                                   Style="{StaticResource CaptionTextBlockStyle}"
                                                                   Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                                                    </StackPanel>
                                                </StackPanel>

                                                <Rectangle Height="1"
                                                           Fill="{ThemeResource SystemControlForegroundBaseHighBrush}"
                                                           Opacity="0.08"/>

                                                <!-- Links row -->
                                                <StackPanel Orientation="Horizontal" Spacing="4">
                                                    <HyperlinkButton NavigateUri="https://fort1nd.com"
                                                                     Padding="8,4" Margin="0">
                                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                                            <FontIcon Glyph="&#xE774;" FontSize="12"/>
                                                            <TextBlock Text="Website" FontSize="12"/>
                                                        </StackPanel>
                                                    </HyperlinkButton>
                                                    <HyperlinkButton x:Name="GitHubLink"
                                                                     NavigateUri="https://github.com/fort-ind/Fort.ind-UWP"
                                                                     Padding="8,4" Margin="0">
                                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                                            <FontIcon Glyph="&#xE943;" FontSize="12"/>
                                                            <TextBlock Text="Source Code" FontSize="12"/>
                                                        </StackPanel>
                                                    </HyperlinkButton>
                                                    <HyperlinkButton x:Name="IssuesLink"
                                                                     NavigateUri="https://github.com/fort-ind/Fort.ind-UWP/issues"
                                                                     Padding="8,4" Margin="0">
                                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                                            <FontIcon Glyph="&#xE946;" FontSize="12"/>
                                                            <TextBlock Text="Report a Bug" FontSize="12"/>
                                                        </StackPanel>
                                                    </HyperlinkButton>
                                                </StackPanel>

                                                <!-- Footer -->
                                                <StackPanel Orientation="Horizontal" Spacing="6" Opacity="0.4">
                                                    <FontIcon Glyph="&#xE734;" FontSize="10" VerticalAlignment="Center"/>
                                                    <TextBlock Text="made with love by fort.ind"
                                                               FontSize="11" VerticalAlignment="Center"/>
                                                    <FontIcon Glyph="&#xE734;" FontSize="10" VerticalAlignment="Center"/>
                                                </StackPanel>

                                            </StackPanel>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Grid>

        </NavigationView>
    </Grid>
</Page>
